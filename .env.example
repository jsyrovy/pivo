# Local secrets for running the app outside CI.
# Copy this file to `.env` and fill in real values:
#
#   cp .env.example .env
#
# `.env` is gitignored and is loaded automatically by the Makefile run targets
# (via `uv run --env-file .env`) whenever the file exists. In CI the same
# targets run without `.env` and read these values from GitHub Secrets instead.

# Untappd RSS archivist feed key (archivist/__init__.py)
FEED_KEY=

# Pushover push notifications (utils/pushover.py)
PUSHOVER_TOKEN=
PUSHOVER_USER_KEY=
